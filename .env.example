# Groq API key — create one at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# LLM model. NOTE: the assignment names gemma2-9b-it, but Groq has decommissioned it.
# We use openai/gpt-oss-20b — a reliable tool-router, lighter than the 70B. You can set
# this to llama-3.3-70b-versatile for a larger model if you have the token headroom.
GROQ_MODEL=openai/gpt-oss-20b

# PostgreSQL connection (only needed for Phase 2 persistence; app runs without it).
# Example: postgresql+psycopg://postgres:postgres@localhost:5432/aivoa_crm
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# CORS origin for the Vite dev server
FRONTEND_ORIGIN=http://localhost:5173
